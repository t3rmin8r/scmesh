---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PageContent from "../components/PageContent.astro";
import PageIntro from "../components/PageIntro.astro";
import loraConfigPage from "../data/pages/loraConfig";
---

<BaseLayout title={loraConfigPage.title} description={loraConfigPage.description}>
  <Hero
    eyebrow={loraConfigPage.heroEyebrow}
    title={loraConfigPage.title}
    body={loraConfigPage.heroBody}
    links={loraConfigPage.heroLinks}
  />
  <PageIntro intro={loraConfigPage.intro} />
  <PageContent content={loraConfigPage} />
</BaseLayout>
