---
import InlineRichText from "./InlineRichText.astro";
import type { LinkCard } from "../types/content";
import type { InlineContent } from "../types/content";
import { getSafeHref, isExternalUrl } from "../utils/paths";

interface Props {
  eyebrow: string;
  title: string;
  body: InlineContent;
  links?: LinkCard[];
  actionsAlign?: "start" | "center";
}

const { eyebrow, title, body, links = [], actionsAlign = "start" } = Astro.props;
---

<section class="hero shell">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-body"><InlineRichText content={body} /></p>
  </div>

  {links.length > 0 && (
    <div class:list={["hero-actions", actionsAlign === "center" && "hero-actions-center"]}>
      {links.map((link) => {
        const href = getSafeHref(link.href);
        const external = href ? isExternalUrl(href) : false;

        if (!href) {
          return null;
        }

        return (
          <a
            class="button-link"
            href={href}
            target={external ? "_blank" : undefined}
            rel={external ? "noreferrer noopener" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  )}
</section>
