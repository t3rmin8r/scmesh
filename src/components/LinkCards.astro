---
import type { LinkCard } from "../types/content";
import { getSafeHref, isExternalUrl } from "../utils/paths";

interface Props {
  cards: LinkCard[];
}

const { cards } = Astro.props;
---

<div class="link-grid">
  {cards.map((card) => {
    const href = getSafeHref(card.href);
    const external = href ? isExternalUrl(href) : false;

    if (!href) {
      return null;
    }

    return (
      <a
        class="link-card"
        href={href}
        target={external ? "_blank" : undefined}
        rel={external ? "noreferrer noopener" : undefined}
      >
        <strong>{card.label}</strong>
        <p>{card.description}</p>
      </a>
    );
  })}
</div>
