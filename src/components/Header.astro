---
import { navItems, site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";
import { withBase } from "../utils/paths";

const currentPath = Astro.url.pathname.replace(/index\.html$/, "");
const normalize = (value: string) => (value.endsWith("/") ? value : `${value}/`);
---

<header class="site-header">
  <div class="shell header-shell">
    <a class="brand" href={withBase("/")}>
      <img class="brand-mark" src={withBase("/favicon.webp")} alt={`${site.shortName} logo`} />
      <span>
        <strong>{site.shortName}</strong>
        <small>Community network docs</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      {navItems.map((item) => {
        const active = normalize(currentPath) === normalize(item.href);

        return (
          <a class:list={["nav-link", active && "active"]} href={withBase(item.href)} aria-current={active ? "page" : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <ThemeToggle />

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobile">
        {navItems.map((item) => {
          const active = normalize(currentPath) === normalize(item.href);

        return (
            <a class:list={["mobile-link", active && "active"]} href={withBase(item.href)} aria-current={active ? "page" : undefined}>
              {item.label}
            </a>
          );
        })}
      </nav>
    </details>
  </div>
</header>
