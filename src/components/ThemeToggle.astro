<div class="theme-toggle">
  <button
    type="button"
    class="theme-icon-button"
    data-theme-switcher
    data-theme-mode="system"
    aria-label="Theme mode: system"
    title="Theme mode: system"
  >
    <span class="sr-only">Change theme</span>

    <svg class="theme-icon" data-icon="light" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="4.25" fill="currentColor" />
      <path
        d="M12 2.5v2.25M12 19.25v2.25M21.5 12h-2.25M4.75 12H2.5M18.72 5.28l-1.59 1.59M6.87 17.13l-1.59 1.59M18.72 18.72l-1.59-1.59M6.87 6.87 5.28 5.28"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-width="1.8"
      />
    </svg>

    <svg class="theme-icon" data-icon="dark" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M18.5 14.6A7.8 7.8 0 0 1 9.4 5.5a8.7 8.7 0 1 0 9.1 9.1Z"
        fill="currentColor"
      />
    </svg>

    <svg class="theme-icon" data-icon="system" viewBox="0 0 24 24" aria-hidden="true">
      <rect x="4" y="5" width="16" height="11" rx="1.75" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M9 19h6M10.5 16.5h3" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  </button>
</div>

<script is:inline>
  (() => {
    const modes = ["light", "dark", "system"];

    const getNextMode = (currentMode) => {
      const currentIndex = modes.indexOf(currentMode);
      return modes[(currentIndex + 1) % modes.length];
    };

    const syncButton = () => {
      const button = document.querySelector("[data-theme-switcher]");
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const currentMode = window.__getThemeMode?.() ?? "system";
      const nextMode = getNextMode(currentMode);
      const label = `Theme mode: ${currentMode}. Click to switch to ${nextMode}.`;

      button.dataset.themeMode = currentMode;
      button.setAttribute("aria-label", label);
      button.title = label;
    };

    document.addEventListener("click", (event) => {
      const button = event.target.closest("[data-theme-switcher]");
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const currentMode = window.__getThemeMode?.() ?? "system";
      window.__setThemeMode?.(getNextMode(currentMode));
    });

    window.addEventListener("theme-mode-change", syncButton);
    document.addEventListener("astro:page-load", syncButton);
    syncButton();
  })();
</script>
