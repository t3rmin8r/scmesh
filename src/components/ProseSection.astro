---
import InlineRichText from "./InlineRichText.astro";
import type { InlineContent } from "../types/content";

interface Props {
  title: string;
  paragraphs?: InlineContent[];
}

const { title, paragraphs = [] } = Astro.props;
---

<section class="content-section">
  <div class="section-heading">
    <h2>{title}</h2>
  </div>
  <div class="prose">
    {paragraphs.map((paragraph) => (
      <p><InlineRichText content={paragraph} /></p>
    ))}
    <slot />
  </div>
</section>
