---
interface Props {
  title: string;
  paragraphs?: string[];
}

const { title, paragraphs = [] } = Astro.props;
---

<section class="content-section">
  <div class="section-heading">
    <h2>{title}</h2>
  </div>
  <div class="prose">
    {paragraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
    <slot />
  </div>
</section>
